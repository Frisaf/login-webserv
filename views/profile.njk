{% extends "layout.njk" %}
{% block content %}
{% include "components/header.njk" %}

<main class="wrapper">
    <h2>Welcome back, {{ data.username }}!</h2>
    <p><a href="/users/logout">Log out</a></p>
    <p><a href="/users/account">Your account</a></p>
    <h3>Your posts</h3>

    {% for post in posts %}
        <article class="post">
            <header>
                <h4>{{ post.title | safe }}</h4>
            </header>
            <p>{{ post.content | safe }}</p>
            <footer>
                <p>Posted by <strong>{{ post.name }}</strong> on {{ post.created_at }}</p>
            </footer>
        </article>
    {% else %}
        <h2>No posts available</h2>
    {% endfor%}
</main>

{% endblock %}